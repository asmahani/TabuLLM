# Copy this file to .env in the repo root and fill in the values you need.
# (.env is gitignored; .env.example is committed)

# Required for OpenAI embedding generation (openai-small, openai-large models).
# Not needed if you only use HF models (minilm, bge-large).
OPENAI_API_KEY=your_key_here

# Optional: path to a local directory containing pre-downloaded HF model weights.
# Set this ONLY if you cannot reach huggingface.co directly (e.g. restricted network).
# When unset, models are downloaded automatically from HF Hub on first use.
#
# Expected subdirectory layout:
#   <HF_MODEL_CACHE_DIR>/all-MiniLM-L6-v2/    (for --model minilm)
#   <HF_MODEL_CACHE_DIR>/bge-large-en-v1.5/   (for --model bge-large)
#
# HF_MODEL_CACHE_DIR=/path/to/local/model/cache
